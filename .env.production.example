# Copy this file to a secure location on the server and pass it with:
# docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

POSTGRES_USER=masar
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=masar

ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://masar:replace-with-a-long-random-password@db:5432/masar
SECRET_KEY=replace-with-at-least-32-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=10080
API_DOCS_ENABLED=false
PLATFORM_TIMEZONE=Asia/Amman
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=3/minute
PASSWORD_CHANGE_RATE_LIMIT=5/hour
CONTACT_RATE_LIMIT=3/minute
BOOKING_RATE_LIMIT=10/minute
BACKEND_CORS_ORIGINS=https://your-domain.example

VITE_API_URL=/api
FRONTEND_PORT=80

# Used only when running:
# docker compose --env-file .env.production -f docker-compose.prod.yml run --rm backend python -m app.bootstrap_admin
ADMIN_EMAIL=admin@your-domain.example
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=Masar Admin
